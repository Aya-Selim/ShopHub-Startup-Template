@{
    ViewData["Title"] = "Access Denied";
}

<div class="container d-flex justify-content-center align-items-center min-vh-100 py-5">
    <div class="card border-0 shadow-lg text-center p-5" style="width: 100%; max-width: 500px; border-radius: 20px; background: #ffffff;">
        <div class="mb-4">
            <i class="fa-solid fa-circle-exclamation text-danger" style="font-size: 80px; filter: drop-shadow(0 4px 10px rgba(220, 53, 69, 0.35));"></i>
        </div>
        <h2 class="fw-bold text-dark mb-3">Access Denied</h2>
        <p class="text-muted mb-4">
            You do not have permission to access this page. This resource is reserved for administrators only.
        </p>
        <div class="d-flex flex-column gap-2">
            <a href="/" class="btn btn-primary py-3 fw-bold text-white border-0" style="background: linear-gradient(135deg, #1e40af 0%, #2563eb 100%); border-radius: 12px; box-shadow: 0 4px 15px rgba(37, 99, 235, 0.35);">
                <i class="fa-solid fa-house me-2"></i>Go to Home Page
            </a>
            <a asp-action="Login" class="btn btn-outline-secondary py-3 fw-bold" style="border-radius: 12px;">
                <i class="fa-solid fa-arrow-right-to-bracket me-2"></i>Log in as Admin
            </a>
        </div>
    </div>
</div>
